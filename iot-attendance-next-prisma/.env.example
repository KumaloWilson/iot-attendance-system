DATABASE_URL="postgresql://postgres:postgres@localhost:5432/iot_attendance?schema=public"
NEXTAUTH_SECRET="change-me-to-a-long-random-secret"
NEXTAUTH_URL="http://localhost:3000"
IOT_API_KEY="fallback-shared-device-key"
APP_BASE_URL="http://localhost:3000"
DEFAULT_IOT_RATE_LIMIT_WINDOW_MS="60000"
DEFAULT_IOT_RATE_LIMIT_MAX="30"

# SMTP email (leave blank to disable email sending — reset URLs will be logged to console)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"
SMTP_FROM="IoT Attendance <no-reply@yourcompany.com>"
